# ── Cockroach Environment Variables ──
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cockroach
REDIS_URL=redis://localhost:6379/0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
VECTOR_DB_BACKEND=faiss          # faiss | qdrant
VECTOR_DB_PATH=./data/faiss
SECRET_KEY=change-me-in-production
AI_BACKEND=local                 # local | openai | anthropic
AI_MODEL=qwen3-coder             # local model name
OPENAI_API_KEY=                  # optional
ANTHROPIC_API_KEY=               # optional
LOG_LEVEL=INFO
ENVIRONMENT=development
